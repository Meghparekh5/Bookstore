<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Edit Book</title>
</head>

<body>

    <h1>Edit Book</h1>

    <a href="/">Back To Home</a>

    <br><br>

    <form action="/update/<%= singleBook._id %>" method="POST" enctype="multipart/form-data">

        <div>
            <label>Book Name</label>
            <br>
            <input type="text" name="bookName" value="<%= singleBook.bookName %>" required>
        </div>

        <br>

        <div>
            <label>Author Name</label>
            <br>
            <input type="text" name="author" value="<%= singleBook.author %>" required>
        </div>

        <br>

        <div>
            <label>Price</label>
            <br>
            <input type="number" name="price" value="<%= singleBook.price %>" required>
        </div>

        <br>

        <div>
            <label>Category</label>
            <br>
            <input type="text" name="category" value="<%= singleBook.category %>" required>
        </div>

        <br>

        <div>
            <label>Description</label>
            <br>
            <textarea name="description" rows="5" cols="40" required><%= singleBook.description %></textarea>
        </div>

        <br>

        <div>
            <label>Current Image</label>
            <br><br>

            <img src="/uploads/<%= singleBook.image %>" alt="<%= singleBook.bookName %>" width="180" height="250">
        </div>

        <br>

        <div>
            <label>Change Image</label>
            <br>
            <input type="file" name="image" accept="image/*">
        </div>

        <br>

        <button type="submit">
            Update Book
        </button>

    </form>

</body>

</html>