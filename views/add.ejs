<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Add Book</title>
</head>

<body>

    <h1>Add New Book</h1>

    <a href="/">Back To Home</a>

    <br><br>

    <form action="/insertBook" method="POST" enctype="multipart/form-data">

        <div>
            <label>Book Name</label>
            <br>
            <input type="text" name="bookName" placeholder="Enter Book Name" required>
        </div>

        <br>

        <div>
            <label>Author Name</label>
            <br>
            <input type="text" name="author" placeholder="Enter Author Name" required>
        </div>

        <br>

        <div>
            <label>Price</label>
            <br>
            <input type="number" name="price" placeholder="Enter Price" required>
        </div>

        <br>

        <div>
            <label>Category</label>
            <br>
            <input type="text" name="category" placeholder="Enter Category" required>
        </div>

        <br>

        <div>
            <label>Description</label>
            <br>
            <textarea name="description" rows="5" cols="40" placeholder="Enter Book Description" required></textarea>
        </div>

        <br>

        <div>
            <label>Book Image</label>
            <br>
            <input type="file" name="image" accept="image/*" required>
        </div>

        <br>

        <button type="submit">
            Add Book
        </button>

    </form>

</body>

</html>