<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Book</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="form-container">

    <h1>Edit Book</h1>

    <form action="/update/<%= singleBook._id %>" method="POST" enctype="multipart/form-data">

        <div class="form-group">
            <label>Book Name</label>
            <input
                type="text"
                name="bookName"
                value="<%= singleBook.bookName %>"
                required>
        </div>

        <div class="form-group">
            <label>Author Name</label>
            <input
                type="text"
                name="author"
                value="<%= singleBook.author %>"
                required>
        </div>

        <div class="form-group">
            <label>Price</label>
            <input
                type="number"
                name="price"
                value="<%= singleBook.price %>"
                required>
        </div>

        <div class="form-group">
            <label>Category</label>
            <input
                type="text"
                name="category"
                value="<%= singleBook.category %>"
                required>
        </div>

        <div class="form-group">
            <label>Description</label>
            <textarea
                name="description"
                rows="5"
                required><%= singleBook.description %></textarea>
        </div>

        <div class="form-group">
            <label>Current Image</label>

            <img
                src="/uploads/<%= singleBook.image %>"
                alt="<%= singleBook.bookName %>"
                class="current-image">
        </div>

        <div class="form-group">
            <label>Change Image</label>
            <input
                type="file"
                name="image"
                accept="image/*">
        </div>

        <button type="submit" class="submit-btn">
            Update Book
        </button>

    </form>

    <br>

    <div class="action-buttons">
        <a href="/" class="btn view-btn">
            Back Home
        </a>
    </div>

</div>

</body>

</html>
